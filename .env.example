# Plato's Planet — Environment Variables
# Copy to .env.local for local development

# App
VITE_APP_NAME="Plato's Planet Digital"
VITE_APP_URL=http://localhost:5173

# Feature flags (set to "true" to enable)
# VITE_ENABLE_AI_TUTOR=true
# VITE_ENABLE_ANALYTICS=false

# AI Tutor — Anthropic API key for live responses (falls back to demo/canned
# answers if unset). NOTE: this ships inside the client bundle since there is
# no backend here — local/demo use only, never deploy publicly with a real key.
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# Future: API endpoints (when backend is added)
# VITE_API_BASE_URL=https://api.platosplanet.com
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
